{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["github>open-pioneer/trails-repo-automation//renovate/base.json"],
    "ignorePaths": ["**/node_modules/**", "**/test-data/**", "**/__snapshots/**"],
    "packageRules": [
        {
            "matchDepTypes": "pnpm.catalog.tests",
            "enabled": false
        },
        {
            "matchDepTypes": ["peerDependencies"],
            "groupName": "Update peer dependencies",
            "description": "Don't update peer dependencies automatically",
            "enabled": false
        },
        {
            "matchUpdateTypes": ["major"],
            "matchPackageNames": ["@pnpm/**"],
            "description": "Dependencies from the pnpm project",
            "groupName": "@pnpm/* dependencies",
            "groupSlug": "pnpm-monorepo-dependencies"
        }
    ]
}
